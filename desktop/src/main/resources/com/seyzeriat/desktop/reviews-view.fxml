<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seyzeriat.desktop.controller.ReviewModerationController"
      styleClass="users-view">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <!-- Header -->
    <Label text="Modération des avis" styleClass="view-title"/>

    <!-- Status bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Pagination Controls -->
        <Button fx:id="prevButton" text="Précédent" onAction="#onPrevPage" styleClass="search-button"/>
        <Label fx:id="pageLabel" text="Page 1/1" styleClass="status-label"/>
        <Button fx:id="nextButton" text="Suivant" onAction="#onNextPage" styleClass="search-button"/>

        <Region minWidth="20"/>

        <Button fx:id="refreshButton" text="Actualiser" onAction="#onRefresh" styleClass="search-button"/>
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="24" prefHeight="24"/>
    </HBox>

    <!-- Reviews table -->
    <TableView fx:id="reviewsTable" VBox.vgrow="ALWAYS" styleClass="users-table">
        <columns>
            <TableColumn fx:id="authorColumn" text="Auteur" prefWidth="120"/>
            <TableColumn fx:id="gameColumn" text="Jeu" prefWidth="180"/>
            <TableColumn fx:id="contentColumn" text="Contenu" prefWidth="350"/>
            <TableColumn fx:id="spoilersColumn" text="Spoilers" prefWidth="70"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="130"/>
            <TableColumn fx:id="actionColumn" text="Action" prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="Aucun avis à afficher." styleClass="status-label"/>
        </placeholder>
    </TableView>
</VBox>
