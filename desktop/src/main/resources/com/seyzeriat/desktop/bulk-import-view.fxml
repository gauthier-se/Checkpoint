<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seyzeriat.desktop.controller.BulkImportController"
      styleClass="bulk-import-view">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <!-- Header -->
    <Label text="Import en masse" styleClass="view-title"/>
    <Label text="Importer plusieurs jeux d'un coup depuis IGDB. Les jeux déjà présents en base sont ignorés."
           styleClass="view-subtitle" wrapText="true"/>

    <!-- Cards row -->
    <HBox spacing="20" alignment="TOP_LEFT">

        <!-- Top-rated card -->
        <VBox spacing="12" styleClass="bulk-import-card" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15"/>
            </padding>

            <Label text="Jeux les mieux notés" styleClass="card-title"/>
            <Label text="Importer les jeux les mieux notés sur IGDB."
                   styleClass="card-subtitle" wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Nombre de jeux :" minWidth="160"/>
                <Spinner fx:id="topRatedLimitSpinner" prefWidth="100" editable="true"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Nombre min. de notes :" minWidth="160"/>
                <Spinner fx:id="minRatingCountSpinner" prefWidth="100" editable="true"/>
            </HBox>

            <Button fx:id="topRatedStartButton" text="Démarrer" onAction="#onStartTopRated"
                    styleClass="primary-button" maxWidth="Infinity"/>
            <Label fx:id="topRatedStatusLabel" styleClass="status-label" wrapText="true"/>
        </VBox>

        <!-- Recent card -->
        <VBox spacing="12" styleClass="bulk-import-card" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15"/>
            </padding>

            <Label text="Sorties récentes" styleClass="card-title"/>
            <Label text="Importer les jeux les plus récemment sortis sur IGDB."
                   styleClass="card-subtitle" wrapText="true"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Nombre de jeux :" minWidth="160"/>
                <Spinner fx:id="recentLimitSpinner" prefWidth="100" editable="true"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="recentStartButton" text="Démarrer" onAction="#onStartRecent"
                    styleClass="primary-button" maxWidth="Infinity"/>
            <Label fx:id="recentStatusLabel" styleClass="status-label" wrapText="true"/>
        </VBox>
    </HBox>

    <!-- Global progress + status -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <ProgressIndicator fx:id="globalProgress" prefWidth="24" prefHeight="24"/>
        <Label fx:id="globalStatusLabel" styleClass="status-label"/>
    </HBox>
</VBox>
