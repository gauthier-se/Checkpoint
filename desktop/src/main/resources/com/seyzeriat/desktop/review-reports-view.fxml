<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seyzeriat.desktop.controller.ReviewReportsController"
      styleClass="users-view">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <!-- Header with back button -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Retour" onAction="#onBack" styleClass="search-button"/>
        <Label fx:id="titleLabel" text="Signalements de l'avis" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="24" prefHeight="24"/>
    </HBox>

    <!-- Review recap -->
    <VBox spacing="8" styleClass="users-table">
        <padding>
            <Insets bottom="12" left="12" right="12" top="12"/>
        </padding>

        <GridPane hgap="15" vgap="6">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Jeu :" styleClass="status-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="gameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Auteur :" styleClass="status-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Label fx:id="authorLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Extrait :" styleClass="status-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <Label fx:id="contentLabel" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <!-- Status bar + pagination -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>

        <Button fx:id="prevButton" text="Précédent" onAction="#onPrevPage" styleClass="search-button"/>
        <Label fx:id="pageLabel" text="Page 1/1" styleClass="status-label"/>
        <Button fx:id="nextButton" text="Suivant" onAction="#onNextPage" styleClass="search-button"/>

        <Region minWidth="20"/>

        <Button fx:id="refreshButton" text="Actualiser" onAction="#onRefresh" styleClass="search-button"/>
    </HBox>

    <!-- Reports table -->
    <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS" styleClass="users-table">
        <columns>
            <TableColumn fx:id="reporterColumn" text="Signalant" prefWidth="180"/>
            <TableColumn fx:id="reasonColumn" text="Raison" prefWidth="480"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="200"/>
        </columns>
        <placeholder>
            <Label text="Aucun signalement pour cet avis." styleClass="status-label"/>
        </placeholder>
    </TableView>
</VBox>
