<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.seyzeriat.desktop.controller.NewsEditorDialogController"
      styleClass="users-view"
      prefWidth="640" prefHeight="560">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Nouvelle actualité" styleClass="view-title"/>

    <Label text="Titre" styleClass="login-field-label"/>
    <TextField fx:id="titleField" promptText="Titre de l'actualité" styleClass="login-text-field"/>

    <Label text="Image de couverture (URL)" styleClass="login-field-label"/>
    <TextField fx:id="pictureField" promptText="https://..." styleClass="login-text-field"/>

    <Label text="Contenu (Markdown)" styleClass="login-field-label"/>
    <TextArea fx:id="contentArea"
              promptText="# Titre&#10;&#10;Contenu en Markdown..."
              wrapText="true"
              VBox.vgrow="ALWAYS"
              styleClass="login-text-field"/>

    <Label fx:id="errorLabel" styleClass="login-error" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="20" prefHeight="20"/>
        <Button fx:id="cancelButton" text="Annuler" onAction="#onCancel" styleClass="search-button"/>
        <Button fx:id="saveButton" text="Enregistrer" onAction="#onSave" styleClass="login-button"/>
    </HBox>
</VBox>
