  name: Get Lists Containing Game
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/api/games/:gameId/lists
  body: none
  auth: none
}

params:path {
  gameId: 9ca266dd-0852-4748-ab5d-f7cf575e9d7a
