meta {
  name: Update Play Log Review
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/me/plays/:playId/review
  body: json
  auth: bearer
}

params:path {
  playId: 9ca266dd-0852-4748-ab5d-f7cf575e9d7a
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "content": "After replaying it, I appreciate it even more. A true masterpiece.",
    "haveSpoilers": false
  }
}
