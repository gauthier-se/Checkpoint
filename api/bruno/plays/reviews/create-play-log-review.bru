meta {
  name: Create Play Log Review
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/me/plays/:playId/review
  body: json
  auth: bearer
}

params:path {
  playId: b4c0be35-1759-4db2-ad35-57e56406078c
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "content": "This game is absolutely amazing! The story and gameplay are top-notch.",
    "haveSpoilers": false
  }
}
